generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      String    @default("equipe")
  permissoes String   @default("[]")
  contatos              Contato[]
  tarefas               Tarefa[]  @relation("TarefaCriador")
  tarefasAtribuidas     Tarefa[]  @relation("TarefaResponsavel")
  eventos               Evento[]
  googleRefreshToken    String?
  createdAt             DateTime  @default(now())
}

model Aluno {
  id               String       @id @default(cuid())
  nome             String
  email            String       @unique
  cpf              String       @default("")
  whatsapp         String
  concurso         String       @default("")
  mediaGeral       Float        @default(0)
  ativo            Boolean      @default(false)
  estudouUltimos7d Boolean      @default(false)
  statusEstudo     String       @default("nao_estudou")
  planoTipo        String       @default("")
  planoVencimento  DateTime?
  discMaisBaixaNome   String   @default("")
  discMaisBaixaNota   Float    @default(0)
  assuntoMaisBaixoNome String  @default("")
  assuntoMaisBaixoNota Float   @default(0)
  diasAtraso          Int      @default(0)
  taxaAcertos         Float    @default(0)
  totalQuestoes       Int      @default(0)
  tutoryId            Int?
  tutoryCreatedAt     DateTime?
  dataInicio          DateTime?
  acompanharDePerto   Boolean  @default(false)
  disciplinas      Disciplina[]
  contatos         Contato[]
  tarefas          Tarefa[]
  eventos          Evento[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Disciplina {
  id      String    @id @default(cuid())
  nome    String
  nota    Float     @default(0)
  alunoId String
  aluno   Aluno     @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  assuntos Assunto[]
}

model Assunto {
  id           String     @id @default(cuid())
  nome         String
  nota         Float      @default(0)
  disciplinaId String
  disciplina   Disciplina @relation(fields: [disciplinaId], references: [id], onDelete: Cascade)
}

model Contato {
  id      String   @id @default(cuid())
  data    DateTime @default(now())
  tipo    String
  obs     String   @default("")
  alunoId String
  aluno   Aluno    @relation(fields: [alunoId], references: [id], onDelete: Cascade)
  userId  String
  user    User     @relation(fields: [userId], references: [id])
}

model Tarefa {
  id              String    @id @default(cuid())
  titulo          String
  descricao       String    @default("")
  concluida       Boolean   @default(false)
  prioridade      String    @default("media")
  dataVencimento  DateTime?
  alunoId         String?
  aluno           Aluno?    @relation(fields: [alunoId], references: [id], onDelete: SetNull)
  userId          String
  user            User      @relation("TarefaCriador", fields: [userId], references: [id])
  responsavelId   String?
  responsavel     User?     @relation("TarefaResponsavel", fields: [responsavelId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Evento {
  id          String   @id @default(cuid())
  titulo      String
  descricao   String   @default("")
  data        DateTime
  tipo        String   @default("lembrete")
  externalUid String?
  alunoId     String?
  aluno       Aluno?   @relation(fields: [alunoId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}
